# Token du bot (onglet "Bot" sur le Discord Developer Portal)
DISCORD_TOKEN=votre_token_ici

# ID de votre serveur Discord (clic droit sur le serveur → Copier l'identifiant)
GUILD_ID=123456789012345678

# URL du projet Supabase (Project Settings → API)
SUPABASE_URL=https://votre-projet.supabase.co

# Clé secrète Supabase (Project Settings → API Keys → clé « secret », format
# sb_secret_… ; PAS la clé publishable sb_publishable_…). Contourne la RLS —
# worker uniquement, ne jamais committer ni exposer côté client.
SUPABASE_SERVICE_KEY=sb_secret_votre_cle_ici
