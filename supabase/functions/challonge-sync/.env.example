# Local secrets for testing the challonge-sync Edge Function (RFC-008).
# Copy to .env.local (git-ignored) and fill in real values — never commit
# the filled-in file. In production these are set via
# `supabase secrets set CHALLONGE_API_KEY=... CHALLONGE_SYNC_SECRET=...`
# (RFC-010's runbook), not a committed file.

# Challonge API key (Settings -> Developer API on challonge.com). Used as
# the `api_key` query parameter on every Challonge API v1 call — see
# index.ts's header comment for why this function uses that method instead
# of HTTP Basic Auth.
CHALLONGE_API_KEY=votre_cle_api_challonge_ici

# Shared secret this function checks against the x-challonge-sync-secret
# request header (F31). For local testing this can be any string you also
# pass back in your curl/test request — it does not need to match anything
# on Challonge's side.
CHALLONGE_SYNC_SECRET=un_secret_local_de_test
